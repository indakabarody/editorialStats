/* Theme: Elegant */
.es-theme-elegant .es-card, .es-theme-elegant .es-box {
	background: #fafafa;
	border: 1px solid #e5e5e5;
	border-radius: 8px;
	box-shadow: 0 4px 15px rgba(0,0,0,0.03);
	color: #333;
}
.es-theme-elegant .es-title, .es-theme-elegant .es-subtitle { color: #111; font-family: "Georgia", serif; letter-spacing: 0.5px; }
.es-theme-elegant .es-card-value { color: #000; font-family: "Georgia", serif; }
.es-theme-elegant .es-card-icon { background: transparent !important; color: #b8905b !important; }
.es-theme-elegant .es-table th { border-bottom: 2px solid #b8905b; color: #111; font-family: "Georgia", serif; }
.es-theme-elegant .es-badge { background-color: #b8905b; color: #fff; }
