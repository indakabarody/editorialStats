/* Theme: Playful */
.es-theme-playful .es-card, .es-theme-playful .es-box {
	background: #fff;
	border: 3px solid #333;
	border-radius: 20px;
	box-shadow: 5px 5px 0px #333;
	transition: transform 0.2s;
}
.es-theme-playful .es-card:hover { transform: translate(-2px, -2px); box-shadow: 7px 7px 0px #333; }
.es-theme-playful .es-title, .es-theme-playful .es-subtitle { color: #333; font-weight: 900; }
.es-theme-playful .es-card-value { color: #ff5e5e; font-weight: 900; }
.es-theme-playful .es-card-icon { background: #ffe45e !important; color: #333 !important; border: 2px solid #333; border-radius: 50%; }
.es-theme-playful .es-table th { border-bottom: 3px solid #333; color: #333; font-weight: 900; }
.es-theme-playful .es-table td { border-bottom: 2px dashed #ccc; }
.es-theme-playful .es-badge { background-color: #333; color: #fff; border-radius: 10px; font-weight: bold; }
